import { AnalyticsCard } from '@/components/common/AnalyticsCard';
import { DataTable, Column } from '@/components/common/DataTable';
import {
  DollarSign,
  ShoppingCart,
  Package,
  Users,
} from 'lucide-react';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Order } from '@/types/index';
import { formatDate } from '@/lib/utils';
import { listOrdersAction } from '@/actions/orders';

interface DashboardPageProps {
  params: { storename: string };
}

// Mock analytics data - Replace with real data when APIs available
const getMockAnalytics = () => ({
  totalRevenue: 45250,
  totalOrders: 234,
  totalProducts: 89,
  totalCustomers: 1245,
  totalReviews: 456,
  revenueGrowth: 12.5,
  orderGrowth: 8.2,
  recentOrders: [
    {
      id: '1',
      orderNumber: 'ORD-001',
      customerId: 'cust-1',
      customerName: 'John Doe',
      customerEmail: 'john@example.com',
      totalAmount: 250,
      itemCount: 3,
      status: 'shipped' as const,
      paymentStatus: 'paid' as const,
      shippingAddress: '123 Main St',
      createdAt: new Date().toISOString(),
      updatedAt: new Date().toISOString(),
    },
  ] as Order[],
  topProducts: [],
});

const orderColumns: Column<Order>[] = [
  { key: 'orderNumber', label: 'Order #' },
  { key: 'customerName', label: 'Customer' },
  { key: 'totalAmount', label: 'Amount', render: (val) => `$${val}` },
  { key: 'status', label: 'Status' },
  {
    key: 'createdAt',
    label: 'Date',
    render: (val) => formatDate(val),
  },
];

export default async function DashboardPage({ params }: DashboardPageProps) {
  const { storename } = params;
  
  // Fetch real data with store context
  try {
    const ordersData = await listOrdersAction({ page: 1, pageSize: 5 }, storename);
    const mockData = getMockAnalytics();
    
    return (
      <div className="space-y-8">
        <div>
          <h1 className="text-3xl font-bold text-gray-900">Dashboard</h1>
          <p className="text-gray-600 mt-1">Welcome to your store admin panel</p>
        </div>

        {/* Analytics Grid */}
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <AnalyticsCard
            title="Total Revenue"
            value={`$${mockData.totalRevenue.toLocaleString()}`}
            change={mockData.revenueGrowth}
            icon={<DollarSign size={20} />}
            trend="up"
          />
          <AnalyticsCard
            title="Total Orders"
            value={mockData.totalOrders}
            change={mockData.orderGrowth}
            icon={<ShoppingCart size={20} />}
            trend="up"
          />
          <AnalyticsCard
            title="Products"
            value={mockData.totalProducts}
            icon={<Package size={20} />}
          />
          <AnalyticsCard
            title="Customers"
            value={mockData.totalCustomers}
            icon={<Users size={20} />}
          />
        </div>

        {/* Recent Orders */}
        <Card>
          <CardHeader>
            <CardTitle>Recent Orders</CardTitle>
          </CardHeader>
          <CardContent>
            <DataTable
              data={ordersData.data.slice(0, 5)}
              columns={orderColumns}
              searchableFields={['customerName', 'orderNumber']}
              pageSize={5}
            />
        </CardContent>
      </Card>
    </div>
  );
}